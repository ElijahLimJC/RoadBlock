{
  "name": "Prompt Security Audit",
  "version": "1.0.0",
  "description": "Verifies persona_engine.py prompt guardrails whenever the file is modified",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/persona_engine.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd /Users/9Elijah_Lim/Downloads/kiro && python settings/scripts/check_prompt_boundaries.py"
  }
}
