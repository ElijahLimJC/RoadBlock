{
  "name": "Threat Parser Regression Check",
  "version": "1.0.0",
  "description": "Runs a quick regression test against static scam data whenever the threat parser is saved, catching breakages before they hit the Streamlit runtime.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/threat_parser.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd /Users/9Elijah_Lim/Downloads/kiro && python settings/scripts/threat_parser_regression.py"
  }
}
